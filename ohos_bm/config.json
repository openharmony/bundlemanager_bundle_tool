{
    "name": "ohos-bm",
    "version": "1.0.0",
    "description": "ohos-bm包管理命令行工具",
    "executable": "/system/bin/cli_tools/ohos_bm",
    "requirePermission": [],
    "hasSubcommands": true,
    "timeout": 30000,
    "output": {
        "type": "object",
        "description": "执行结果",
        "properties": {
            "success": {
                "type": "boolean"
            },
            "message": {
                "type": "string"
            },
            "code": {
                "type": "string"
            },
            "cause": {
                "type": "string"
            },
            "suggestion": {
                "type": "string"
            }
        }
    },
    "events": ["result"],
    "eventSchemas": {},
    "subcommands": {
        "help": {
            "description": "查看ohos-bm相关子命令的信息",
            "requiredPermission": [],
            "input": {
                "type": "object",
                "properties": {}
            },
            "argumentMapping": {},
            "output": {
                "type": "object",
                "description": "执行结果",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "code": {
                        "type": "string"
                    },
                    "cause": {
                        "type": "string"
                    },
                    "suggestion": {
                        "type": "string"
                    }
                }
            },
            "events": ["result"],
            "eventSchemas": {}
        },
        "install": {
            "description": "安装一个hap、hsp或app包",
            "requiredPermission": [],
            "input": {
                "type": "object",
                "properties": {
                    "help": {
                        "type": "boolean",
                        "default": false
                    },
                    "bundlePath": {
                        "type": "string",
                        "description": "安装包文件路径",
                        "default": ""
                    },
                    "replace": {
                        "type": "boolean",
                        "default": false
                    },
                    "sharedBundleDirPath": {
                        "type": "string",
                        "description": "安装跨应用hsp文件的目录路径",
                        "default": ""
                    },
                    "userId": {
                        "type": "string",
                        "description": "指定用户ID",
                        "default": ""
                    },
                    "waittingTime": {
                        "type": "string",
                        "description": "指定安装等待时间（180-600秒）",
                        "default": ""
                    },
                    "downgrade": {
                        "type": "boolean",
                        "default": false
                    },
                    "grantPermission": {
                        "type": "boolean",
                        "default": false
                    }
                }
            },
            "output": {
                "type": "object",
                "description": "执行结果",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "code": {
                        "type": "string"
                    },
                    "cause": {
                        "type": "string"
                    },
                    "suggestion": {
                        "type": "string"
                    }
                }
            },
            "events": ["result"],
            "eventSchemas": {},
            "argumentMapping": {
                "type": "flag",
                "templates": {
                    "help": {
                        "if_true": "-h",
                        "if_false": ""
                    },
                    "bundlePath": "-p={value}",
                    "replace": {
                        "if_true": "-r",
                        "if_false": ""
                    },
                    "sharedBundleDirPath": "-s={value}",
                    "userId": "-u={value}",
                    "waittingTime": "-w={value}",
                    "downgrade": {
                        "if_true": "-d",
                        "if_false": ""
                    },
                    "grantPermission": {
                        "if_true": "-g",
                        "if_false": ""
                    }
                }
            }
        },
        "uninstall": {
            "description": "卸载一个应用包",
            "requiredPermission": [],
            "input": {
                "type": "object",
                "properties": {
                    "help": {
                        "type": "boolean",
                        "default": false
                    },
                    "bundleName": {
                        "type": "string",
                        "description": "要卸载的应用包名",
                        "default": ""
                    },
                    "moduleName": {
                        "type": "string",
                        "description": "要卸载的模块名",
                        "default": ""
                    },
                    "userId": {
                        "type": "string",
                        "description": "指定用户ID",
                        "default": ""
                    },
                    "keepData": {
                        "type": "boolean",
                        "default": false
                    },
                    "shared": {
                        "type": "boolean",
                        "default": false
                    },
                    "version": {
                        "type": "string",
                        "description": "按版本号卸载跨应用共享库",
                        "default": ""
                    }
                }
            },
            "output": {
                "type": "object",
                "description": "执行结果",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "code": {
                        "type": "string"
                    },
                    "cause": {
                        "type": "string"
                    },
                    "suggestion": {
                        "type": "string"
                    }
                }
            },
            "events": ["result"],
            "eventSchemas": {},
            "argumentMapping": {
                "type": "flag",
                "templates": {
                    "help": {
                        "if_true": "-h",
                        "if_false": ""
                    },
                    "bundleName": "-n={value}",
                    "moduleName": "-m={value}",
                    "userId": "-u={value}",
                    "keepData": {
                        "if_true": "-k",
                        "if_false": ""
                    },
                    "shared": {
                        "if_true": "-s",
                        "if_false": ""
                    },
                    "version": "-v={value}"
                }
            }
        },
        "dump": {
            "description": "查看应用包信息",
            "requiredPermission": [],
            "input": {
                "type": "object",
                "properties": {
                    "help": {
                        "type": "boolean",
                        "default": false
                    },
                    "all": {
                        "type": "boolean",
                        "default": false
                    },
                    "debugBundle": {
                        "type": "boolean",
                        "default": false
                    },
                    "bundleName": {
                        "type": "string",
                        "description": "指定应用包名",
                        "default": ""
                    },
                    "shortcutInfo": {
                        "type": "boolean",
                        "default": false
                    },
                    "deviceId": {
                        "type": "string",
                        "description": "指定设备ID",
                        "default": ""
                    },
                    "userId": {
                        "type": "string",
                        "description": "指定用户ID",
                        "default": ""
                    },
                    "label": {
                        "type": "boolean",
                        "default": false
                    }
                }
            },
            "output": {
                "type": "object",
                "description": "执行结果",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "code": {
                        "type": "string"
                    },
                    "cause": {
                        "type": "string"
                    },
                    "suggestion": {
                        "type": "string"
                    },
                    "data": {
                        "type": "string"
                    }
                }
            },
            "events": ["result"],
            "eventSchemas": {},
            "argumentMapping": {
                "type": "flag",
                "templates": {
                    "help": {
                        "if_true": "-h",
                        "if_false": ""
                    },
                    "all": {
                        "if_true": "-a",
                        "if_false": ""
                    },
                    "debugBundle": {
                        "if_true": "-g",
                        "if_false": ""
                    },
                    "bundleName": "-n={value}",
                    "shortcutInfo": {
                        "if_true": "-s",
                        "if_false": ""
                    },
                    "deviceId": "-d={value}",
                    "userId": "-u={value}",
                    "label": {
                        "if_true": "-l",
                        "if_false": ""
                    }
                }
            }
        },
        "dump-dependencies": {
            "description": "查看指定应用和模块的依赖信息",
            "requiredPermission": [],
            "input": {
                "type": "object",
                "properties": {
                    "help": {
                        "type": "boolean",
                        "default": false
                    },
                    "bundleName": {
                        "type": "string",
                        "description": "指定应用包名",
                        "default": ""
                    },
                    "moduleName": {
                        "type": "string",
                        "description": "指定模块名",
                        "default": ""
                    }
                }
            },
            "output": {
                "type": "object",
                "description": "执行结果",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "code": {
                        "type": "string"
                    },
                    "cause": {
                        "type": "string"
                    },
                    "suggestion": {
                        "type": "string"
                    },
                    "data": {
                        "type": "string"
                    }
                }
            },
            "events": ["result"],
            "eventSchemas": {},
            "argumentMapping": {
                "type": "flag",
                "templates": {
                    "help": {
                        "if_true": "-h",
                        "if_false": ""
                    },
                    "bundleName": "-n={value}",
                    "moduleName": "-m={value}"
                }
            }
        },
        "dump-shared": {
            "description": "查看跨应用共享库信息",
            "requiredPermission": [],
            "input": {
                "type": "object",
                "properties": {
                    "help": {
                        "type": "boolean",
                        "default": false
                    },
                    "all": {
                        "type": "boolean",
                        "default": false
                    },
                    "bundleName": {
                        "type": "string",
                        "description": "指定应用包名",
                        "default": ""
                    }
                }
            },
            "output": {
                "type": "object",
                "description": "执行结果",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "code": {
                        "type": "string"
                    },
                    "cause": {
                        "type": "string"
                    },
                    "suggestion": {
                        "type": "string"
                    },
                    "data": {
                        "type": "string"
                    }
                }
            },
            "events": ["result"],
            "eventSchemas": {},
            "argumentMapping": {
                "type": "flag",
                "templates": {
                    "help": {
                        "if_true": "-h",
                        "if_false": ""
                    },
                    "all": {
                        "if_true": "-a",
                        "if_false": ""
                    },
                    "bundleName": "-n={value}"
                }
            }
        },
        "clean": {
            "description": "清理应用缓存或数据文件",
            "requiredPermission": [],
            "input": {
                "type": "object",
                "properties": {
                    "help": {
                        "type": "boolean",
                        "default": false
                    },
                    "bundleName": {
                        "type": "string",
                        "description": "指定应用包名",
                        "default": ""
                    },
                    "cache": {
                        "type": "boolean",
                        "default": false
                    },
                    "data": {
                        "type": "boolean",
                        "default": false
                    },
                    "userId": {
                        "type": "string",
                        "description": "指定用户ID",
                        "default": ""
                    },
                    "appIndex": {
                        "type": "string",
                        "description": "指定应用索引",
                        "default": ""
                    }
                }
            },
            "output": {
                "type": "object",
                "description": "执行结果",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "code": {
                        "type": "string"
                    },
                    "cause": {
                        "type": "string"
                    },
                    "suggestion": {
                        "type": "string"
                    }
                }
            },
            "events": ["result"],
            "eventSchemas": {},
            "argumentMapping": {
                "type": "flag",
                "templates": {
                    "help": {
                        "if_true": "-h",
                        "if_false": ""
                    },
                    "bundleName": "-n={value}",
                    "cache": {
                        "if_true": "-c",
                        "if_false": ""
                    },
                    "data": {
                        "if_true": "-d",
                        "if_false": ""
                    },
                    "userId": "-u={value}",
                    "appIndex": "-i={value}"
                }
            }
        },
        "set-disposed-rule": {
            "description": "设置分身应用的处置规则，用于控制应用组件的运行行为",
            "requiredPermission": [],
            "input": {
                "type": "object",
                "required": ["appId", "priority", "componentType", "disposedType", "controlType", "wantBundleName", "wantAbilityName"],
                "properties": {
                    "help": {
                        "type": "boolean",
                        "default": false
                    },
                    "appId": {
                        "type": "string",
                        "description": "应用的appId或appIdentifier"
                    },
                    "appIndex": {
                        "type": "string",
                        "description": "分身应用索引，正整数"
                    },
                    "priority": {
                        "type": "string",
                        "description": "处置规则优先级，非负整数，数值越大优先级越高"
                    },
                    "componentType": {
                        "type": "string",
                        "description": "受控制的组件类型：1=UI_ABILITY，2=UI_EXTENSION",
                        "enum": ["1", "2"]
                    },
                    "disposedType": {
                        "type": "string",
                        "description": "处置类型：1=BLOCK_APPLICATION(阻止应用)，2=BLOCK_ABILITY(阻止组件)，3=NON_BLOCK(非阻断)",
                        "enum": ["1", "2", "3"]
                    },
                    "controlType": {
                        "type": "string",
                        "description": "控制类型：1=ALLOWED_LIST(允许名单)，2=DISALLOWED_LIST(阻止名单)",
                        "enum": ["1", "2"]
                    },
                    "elements": {
                        "type": "array",
                        "description": "受控组件元素列表，格式为/bundleName/moduleName/abilityName，可指定多个",
                        "items": {
                            "type": "string"
                        }
                    },
                    "wantBundleName": {
                        "type": "string",
                        "description": "Want重定向目标的bundleName"
                    },
                    "wantModuleName": {
                        "type": "string",
                        "description": "Want重定向目标的moduleName"
                    },
                    "wantAbilityName": {
                        "type": "string",
                        "description": "Want重定向目标的abilityName"
                    },
                    "wantParamsStrings": {
                        "type": "array",
                        "description": "Want的string类型附加参数，格式为key value，可指定多组",
                        "items": {
                            "type": "string"
                        }
                    },
                    "wantParamsInts": {
                        "type": "array",
                        "description": "Want的int类型附加参数，格式为key value，可指定多组",
                        "items": {
                            "type": "string"
                        }
                    },
                    "wantParamsBools": {
                        "type": "array",
                        "description": "Want的bool类型附加参数，格式为key true/false，可指定多组",
                        "items": {
                            "type": "string"
                        }
                    }
                }
            },
            "output": {
                "type": "object",
                "description": "执行结果",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "code": {
                        "type": "string"
                    },
                    "cause": {
                        "type": "string"
                    },
                    "suggestion": {
                        "type": "string"
                    }
                }
            },
            "events": ["result"],
            "eventSchemas": {},
            "argumentMapping": {
                "type": "flag",
                "templates": {
                    "help": {
                        "if_true": "-h",
                        "if_false": ""
                    },
                    "appId": "--app-id {value}",
                    "appIndex": "--app-index {value}",
                    "priority": "--priority {value}",
                    "componentType": "--component-type {value}",
                    "disposedType": "--disposed-type {value}",
                    "controlType": "--control-type {value}",
                    "elements": "--element {value}",
                    "wantBundleName": "--want-bundle-name {value}",
                    "wantModuleName": "--want-module-name {value}",
                    "wantAbilityName": "--want-ability-name {value}",
                    "wantParamsStrings": "--want-ps {value}",
                    "wantParamsInts": "--want-pi {value}",
                    "wantParamsBools": "--want-pb {value}"
                }
            }
        },
        "delete-disposed-rule": {
            "description": "删除分身应用的处置规则",
            "requiredPermission": [],
            "input": {
                "type": "object",
                "required": ["appId"],
                "properties": {
                    "help": {
                        "type": "boolean",
                        "default": false
                    },
                    "appId": {
                        "type": "string",
                        "description": "应用的appId或appIdentifier"
                    },
                    "appIndex": {
                        "type": "string",
                        "description": "分身应用索引，正整数"
                    }
                }
            },
            "output": {
                "type": "object",
                "description": "执行结果",
                "properties": {
                    "success": {
                        "type": "boolean"
                    },
                    "message": {
                        "type": "string"
                    },
                    "code": {
                        "type": "string"
                    },
                    "cause": {
                        "type": "string"
                    },
                    "suggestion": {
                        "type": "string"
                    }
                }
            },
            "events": ["result"],
            "eventSchemas": {},
            "argumentMapping": {
                "type": "flag",
                "templates": {
                    "help": {
                        "if_true": "-h",
                        "if_false": ""
                    },
                    "appId": "--app-id {value}",
                    "appIndex": "--app-index {value}"
                }
            }
        }
    }
}