        "set-disposed-rule": {
            "description": "Set disposed rule for clone app to control component behavior",
            "requirePermissions": ["ohos.permission.cli.MANAGE_DISPOSED_APP_STATUS"],
            "inputSchema": {
                "type": "object",
                "required": [
                    "appId",
                    "priority",
                    "componentType",
                    "disposedType",
                    "controlType",
                    "wantBundleName",
                    "wantAbilityName"
                ],
                "properties": {
                    "help": {
                        "type": "boolean",
                        "default": false
                    },
                    "appId": {
                        "type": "string",
                        "description": "Application appId or appIdentifier"
                    },
                    "appIndex": {
                        "type": "string",
                        "description": "Clone app index, a positive integer"
                    },
                    "priority": {
                        "type": "string",
                        "description": "Disposed rule priority, non-negative integer, higher value means higher priority"
                    },
                    "componentType": {
                        "type": "string",
                        "description": "Component type to control: 1=UI_ABILITY, 2=UI_EXTENSION"
                    },
                    "disposedType": {
                        "type": "string",
                        "description": "Disposed type: 1=BLOCK_APPLICATION, 2=BLOCK_ABILITY, 3=NON_BLOCK"
                    },
                    "controlType": {
                        "type": "string",
                        "description": "Control type: 1=ALLOWED_LIST, 2=DISALLOWED_LIST"
                    },
                    "elements": {
                        "type": "array",
                        "description": "Controlled component element list, format: /bundleName/moduleName/abilityName, multiple elements allowed",
                        "items": {
                            "type": "string"
                        }
                    },
                    "wantBundleName": {
                        "type": "string",
                        "description": "Want redirection target bundleName"
                    },
                    "wantModuleName": {
                        "type": "string",
                        "description": "Want redirection target moduleName"
                    },
                    "wantAbilityName": {
                        "type": "string",
                        "description": "Want redirection target abilityName"
                    },
                    "wantParamsStrings": {
                        "type": "array",
                        "description": "Want string type additional parameters, format: key value, multiple groups allowed",
                        "items": {
                            "type": "string"
                        }
                    },
                    "wantParamsInts": {
                        "type": "array",
                        "description": "Want int type additional parameters, format: key value, multiple groups allowed",
                        "items": {
                            "type": "string"
                        }
                    },
                    "wantParamsBools": {
                        "type": "array",
                        "description": "Want bool type additional parameters, format: key true/false, multiple groups allowed",
                        "items": {
                            "type": "string"
                        }
                    }
